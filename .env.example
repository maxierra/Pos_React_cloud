# --- Monitoreo (admin → Monitoreo): guarda tiempos de server actions en Supabase ---
# En local ya se registra por defecto; en producción (Vercel, etc.) poné true para ver métricas.
# Requiere ejecutar supabase/monitoring_schema.sql en el SQL Editor de Supabase al menos una vez.
NEXT_PUBLIC_ENABLE_MONITORING=true

# --- Supabase (ya los tenés para la app) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor: copiá desde Supabase → Settings → API → service_role (NUNCA en el cliente).
# La usa el webhook de Mercado Pago, y guardar/leer el access token de MP por negocio (QR en el POS).
SUPABASE_SERVICE_ROLE_KEY=

# Panel /app/admin: emails que pueden activar suscripciones manualmente (separados por coma). Mismo mail que usás en Supabase Auth.
PLATFORM_ADMIN_EMAILS=tu-cuenta@ejemplo.com
# Días de acceso al pulsar "Activar" en admin (si no está definido, usa MERCADOPAGO_BILLING_PERIOD_DAYS).
MANUAL_SUBSCRIPTION_PERIOD_DAYS=30

# URL pública de la app (sin barra final). Ej: https://tudominio.com
# Podés poner solo el dominio (sin https); en producción se asume https (requerido por Mercado Pago).
# Podés usar NEXT_PUBLIC_APP_URL o APP_BASE_URL (misma idea que en auth/callback).
# En Vercel podés dejar ambas vacías y se usa VERCEL_URL.
# En Render, si no definís nada, se usa RENDER_EXTERNAL_URL (la inyecta Render; necesaria para Mercado Pago).
# En local sin variables: http://localhost:3000
NEXT_PUBLIC_APP_URL=
APP_BASE_URL=

# --- Mercado Pago (servidor) ---
# Token de acceso desde: Tu negocio → Credenciales → Credenciales de prueba / producción
# Prueba: suele empezar con TEST-  |  Producción: APP_USR-...
# NO uses la Public Key acá; el Access Token es secreto y solo va en el servidor.
MERCADOPAGO_ACCESS_TOKEN=

# Usar checkout de sandbox (URLs de prueba). Poné 1 si tu token es de prueba.
MERCADOPAGO_USE_SANDBOX=1

# --- Planes de suscripción (3 opciones) ---
# Moneda (aplica a todos los planes).
MERCADOPAGO_PLAN_CURRENCY=ARS

# Plan mensual (base): precio por mes y días de acceso.
MERCADOPAGO_PLAN_MONTHLY_AMOUNT=15
MERCADOPAGO_PLAN_MONTHLY_DAYS=30
MERCADOPAGO_PLAN_MONTHLY_TITLE=Plan mensual — Punto de venta

# Plan semestral (6 meses): precio total con descuento y días de acceso.
# Sin descuento serían 6 × mensual = 90. Acá ponés lo que realmente cobrás.
MERCADOPAGO_PLAN_SEMESTER_AMOUNT=80
MERCADOPAGO_PLAN_SEMESTER_DAYS=180
MERCADOPAGO_PLAN_SEMESTER_TITLE=Plan semestral — Punto de venta

# Plan anual (12 meses): precio total con descuento y días de acceso.
# Sin descuento serían 12 × mensual = 180. Acá ponés lo que realmente cobrás.
MERCADOPAGO_PLAN_ANNUAL_AMOUNT=150
MERCADOPAGO_PLAN_ANNUAL_DAYS=365
MERCADOPAGO_PLAN_ANNUAL_TITLE=Plan anual — Punto de venta

# La duración de la PRUEBA GRATIS no va acá: está en Supabase → tabla platform_settings (intervalo).
# Ver supabase/SUBSCRIPTION_TRIAL.md (ej. 5 minutes para testear el bloqueo).

# --- Activación manual / sin checkout MP (opcional, todo NEXT_PUBLIC_ para mostrarse en el navegador) ---
# Si falta MERCADOPAGO_ACCESS_TOKEN, el botón de pago se deshabilita y se muestra esto con más énfasis.
NEXT_PUBLIC_SUBSCRIPTION_MANUAL_MP_ALIAS=tienda360.mp
NEXT_PUBLIC_SUBSCRIPTION_MANUAL_PHONE=11 2314-5742
# Solo dígitos, formato internacional sin +: Argentina celular = 54 + 9 + código área sin 0 + número (ej. 5491123145742)
NEXT_PUBLIC_SUBSCRIPTION_MANUAL_WHATSAPP=5491123145742
# Opcional: CBU/CVU, titular y texto para el cliente (transferencia bancaria).
NEXT_PUBLIC_SUBSCRIPTION_MANUAL_CBU=
NEXT_PUBLIC_SUBSCRIPTION_MANUAL_TRANSFER_HOLDER=
NEXT_PUBLIC_SUBSCRIPTION_MANUAL_TRANSFER_NOTE=En el concepto indicá el importe y el ID de tu negocio que figura en la app.

# Opcional: la Public Key solo hace falta si más adelante usás el SDK en el navegador (Bricks, etc.).
# NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# --- Correo (Resend): reportes diarios, cron y alertas de admin (/admin/alertas) ---
# API key desde https://resend.com/api-keys
# RESEND_API_KEY=
# Remitente verificado en Resend (dominio propio). Si no definís, se usa el de prueba de Resend.
# RESEND_FROM="POS <notificaciones@tudominio.com>"
